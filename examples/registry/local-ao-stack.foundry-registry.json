{
  "schema_version": "ao.foundry.registry.v0.1",
  "foundry_id": "local-ao-stack",
  "name": "Local AO Stack",
  "repos": [
    {
      "id": "ao-foundry",
      "name": "AO Foundry",
      "role": "operations-factory",
      "delegates_to": "ao-forge",
      "workspace": "../ao-foundry",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "readiness-audit",
          "location": "examples/readiness/ao-foundry-bootstrap.production-readiness-audit.json",
          "owner": "ao-foundry"
        }
      ],
      "allowed_automation": ["readiness-audit", "forge-brief"],
      "readiness_signals": [
        {
          "name": "foundry-tests",
          "status": "ready",
          "source": "go test ./..."
        }
      ]
    },
    {
      "id": "ao-forge",
      "name": "AO Forge",
      "role": "factory-brain",
      "delegates_to": "ao2",
      "workspace": "../ao-forge",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "forge-packet",
          "location": "examples/packets/ao-foundry-bootstrap.factory-packet.json",
          "owner": "ao-forge"
        }
      ],
      "allowed_automation": ["plan", "gate", "run-local"],
      "readiness_signals": [
        {
          "name": "forge-tests",
          "status": "ready",
          "source": "go test ./..."
        }
      ]
    },
    {
      "id": "ao-command",
      "name": "AO Command",
      "role": "operator-command",
      "delegates_to": "ao-forge",
      "workspace": "../ao-command",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "operator-status",
          "location": "operator-summary",
          "owner": "ao-command"
        }
      ],
      "allowed_automation": ["read-status", "summarize"],
      "readiness_signals": [
        {
          "name": "command-surface",
          "status": "ready",
          "source": "registered for read-only operator workflows"
        }
      ]
    },
    {
      "id": "ao-operator",
      "name": "AO Operator",
      "role": "operator-command",
      "delegates_to": "ao2",
      "workspace": "../ao-operator",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "archive-status",
          "location": "../ao-operator/docs/archive-handoff.md",
          "owner": "ao-operator"
        }
      ],
      "allowed_automation": ["archive-read"],
      "readiness_signals": [
        {
          "name": "archive-handoff",
          "status": "ready",
          "source": "deprecated and replaced by ao2 plus ao2-control-plane; keep as reference-only"
        }
      ]
    },
    {
      "id": "ao2",
      "name": "AO2",
      "role": "execution-engine",
      "delegates_to": "ao-forge",
      "workspace": "../ao2",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "sdd-run",
          "location": "examples/runs/ao-foundry-bootstrap.sdd-run.yaml",
          "owner": "ao2"
        }
      ],
      "allowed_automation": ["sdd-plan", "sdd-dispatch", "dry-run"],
      "readiness_signals": [
        {
          "name": "sdd-cli",
          "status": "ready",
          "source": "ao2 sdd --help"
        }
      ]
    },
    {
      "id": "codex-cron",
      "name": "codex-cron",
      "role": "operations-factory",
      "delegates_to": "ao-foundry",
      "workspace": "../codex-cron",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "scheduler-status",
          "location": "codex-cron doctor",
          "owner": "codex-cron"
        }
      ],
      "allowed_automation": ["read-schedule", "tick-local"],
      "readiness_signals": [
        {
          "name": "durable-scheduler",
          "status": "ready",
          "source": "active spine scheduler for overnight Foundry loops"
        }
      ]
    },
    {
      "id": "ao2-control-plane",
      "name": "AO2 Control Plane",
      "role": "evidence-observer",
      "delegates_to": "ao-forge",
      "workspace": "../ao2-control-plane",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "readback",
          "location": "optional-control-plane-readback",
          "owner": "ao2-control-plane"
        }
      ],
      "allowed_automation": ["read-evidence", "report-retention"],
      "readiness_signals": [
        {
          "name": "observer-boundary",
          "status": "ready",
          "source": "control plane is not required for local v0.1"
        }
      ]
    },
    {
      "id": "ao-covenant",
      "name": "AO Covenant",
      "role": "policy-kernel",
      "delegates_to": "ao-forge",
      "workspace": "../ao-covenant",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "gate-result",
          "location": "examples/gates/ao-foundry-bootstrap.gate.json",
          "owner": "ao-covenant"
        }
      ],
      "allowed_automation": ["evaluate-local-plan", "fail-closed"],
      "readiness_signals": [
        {
          "name": "covenant-binary",
          "status": "ready",
          "source": "local build for Forge gate"
        }
      ]
    },
    {
      "id": "agy-swarms",
      "name": "agy-swarms",
      "role": "agent-orchestrator",
      "delegates_to": "ao-forge",
      "workspace": "../agy-swarms",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "archive-status",
          "location": "../agy-swarms/docs/archive-handoff.md",
          "owner": "agy-swarms"
        }
      ],
      "allowed_automation": ["archive-read"],
      "readiness_signals": [
        {
          "name": "archive-handoff",
          "status": "ready",
          "source": "archive handoff captured; keep as reference-only and out of active AO spine work"
        }
      ]
    },
    {
      "id": "ao-conductor",
      "name": "AO Conductor",
      "role": "workflow-conductor",
      "delegates_to": "ao-forge",
      "workspace": "../ao-conductor",
      "branches": ["main"],
      "evidence_sources": [
        {
          "kind": "archive-status",
          "location": "../ao-conductor/docs/archive-handoff.md",
          "owner": "ao-conductor"
        }
      ],
      "allowed_automation": ["archive-read"],
      "readiness_signals": [
        {
          "name": "archive-handoff",
          "status": "ready",
          "source": "archive handoff captured; keep as reference-only and out of active AO spine work"
        }
      ]
    }
  ]
}
