{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-atlas-readback-v0.1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "mode",
    "atlas_import_id",
    "workgraph_id",
    "target_instance",
    "task_id",
    "task_digest",
    "run_link_digest",
    "evidence",
    "schedules_work",
    "executes_work",
    "approves_work",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.atlas-readback.v0.1" },
    "status": { "enum": ["ready", "blocked"] },
    "mode": { "const": "fixture_only_readback" },
    "atlas_import_id": { "type": "string", "minLength": 1 },
    "workgraph_id": { "type": "string", "minLength": 1 },
    "target_instance": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "task_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "run_link_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "evidence": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
