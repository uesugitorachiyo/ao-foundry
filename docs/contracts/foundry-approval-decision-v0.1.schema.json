{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-approval-decision-v0.1.schema.json",
  "title": "AO Foundry Approval Decision v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "task_sha256",
    "requested_side_effects",
    "approved_side_effects",
    "expires_at_utc",
    "operator",
    "reason",
    "decision"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.approval-decision.v0.1" },
    "task_id": { "type": "string", "minLength": 1 },
    "task_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "requested_side_effects": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "approved_side_effects": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "expires_at_utc": { "type": "string", "format": "date-time" },
    "operator": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "enum": ["approved", "denied"] }
  }
}
