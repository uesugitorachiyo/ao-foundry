{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-mutation-class-gate-v0.1.schema.json",
  "title": "AO Foundry Mutation Class Gate v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "mutation_class",
    "safe_to_request",
    "safe_to_execute",
    "first_failing_check",
    "required_evidence",
    "source_evidence",
    "denied_classes",
    "authority_boundary",
    "next_actions",
    "schedules_work",
    "executes_work",
    "approves_work",
    "mutates_repositories"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.mutation-class-gate.v0.1" },
    "status": { "enum": ["ready", "blocked"] },
    "mutation_class": { "$ref": "#/$defs/mutation_class" },
    "safe_to_request": { "type": "boolean" },
    "safe_to_execute": { "type": "boolean" },
    "first_failing_check": { "type": "string" },
    "required_evidence": {
      "type": "array",
      "minItems": 7,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_evidence": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "schema_version", "status", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "schema_version": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "class_boundary_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutation_class",
        "atlas_classification_only",
        "atlas_required_gates_complete",
        "covenant_exact_scope",
        "covenant_class_bound",
        "covenant_digest_bound",
        "covenant_single_use",
        "covenant_unconsumed",
        "covenant_live_mutation_denied",
        "sentinel_no_hold",
        "promoter_boundary",
        "rollback_patch_present",
        "rollback_verification_commands_present",
        "command_read_only",
        "command_current_class",
        "command_next_class",
        "command_mutates_repositories",
        "ci_passed",
        "ci_required_checks_present",
        "test_only_live_evidence",
        "safe_to_request",
        "safe_to_execute"
      ],
      "properties": {
        "mutation_class": { "$ref": "#/$defs/mutation_class" },
        "atlas_classification_only": { "type": "boolean" },
        "atlas_required_gates_complete": { "type": "boolean" },
        "covenant_exact_scope": { "type": "boolean" },
        "covenant_class_bound": { "type": "boolean" },
        "covenant_digest_bound": { "type": "boolean" },
        "covenant_single_use": { "type": "boolean" },
        "covenant_unconsumed": { "type": "boolean" },
        "covenant_live_mutation_denied": { "type": "boolean" },
        "sentinel_no_hold": { "type": "boolean" },
        "promoter_boundary": { "type": "string", "minLength": 1 },
        "rollback_patch_present": { "type": "boolean" },
        "rollback_verification_commands_present": { "type": "boolean" },
        "command_read_only": { "type": "boolean" },
        "command_current_class": { "$ref": "#/$defs/mutation_class" },
        "command_next_class": { "$ref": "#/$defs/mutation_class" },
        "command_mutates_repositories": { "type": "boolean" },
        "ci_passed": { "type": "boolean" },
        "ci_required_checks_present": { "type": "boolean" },
        "test_only_live_evidence": { "type": "boolean" },
        "safe_to_request": { "type": "boolean" },
        "safe_to_execute": { "const": false }
      }
    },
    "denied_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mutation_class" }
    },
    "authority_boundary": { "const": "single_class_only" },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "denial_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "status",
        "mutation_class",
        "current_proven_live_class",
        "next_denied_class",
        "safe_to_request",
        "safe_to_execute",
        "missing_policy_evidence",
        "missing_rollback_evidence",
        "missing_sentinel_promoter_evidence",
        "sentinel_state",
        "promoter_state",
        "ci_requirements",
        "exact_next_action",
        "denial_reason"
      ],
      "properties": {
        "schema_version": { "const": "ao.foundry.low-risk-code-denial-audit.v0.1" },
        "status": { "const": "blocked" },
        "mutation_class": { "const": "low_risk_code" },
        "current_proven_live_class": { "const": "test_only" },
        "next_denied_class": { "const": "low_risk_code" },
        "safe_to_request": { "type": "boolean" },
        "safe_to_execute": { "const": false },
        "missing_policy_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "missing_rollback_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "missing_sentinel_promoter_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "sentinel_state": { "type": "string", "minLength": 1 },
        "promoter_state": { "type": "string", "minLength": 1 },
        "ci_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "exact_next_action": { "const": "build_low_risk_code_promotion_prerequisites" },
        "denial_reason": { "type": "string", "minLength": 1 }
      }
    },
    "live_rehearsal_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "status",
        "mutation_class",
        "current_class",
        "next_class",
        "current_proven_live_class",
        "lower_class_live_evidence_status",
        "safe_to_request",
        "safe_to_execute",
        "live_execution_authority",
        "missing_evidence",
        "denial_reason",
        "exact_next_action",
        "repo_execution_policy",
        "schedules_work",
        "executes_work",
        "mutates_repositories"
      ],
      "properties": {
        "schema_version": { "const": "ao.foundry.multi-repo-live-rehearsal-decision.v0.1" },
        "status": { "enum": ["denied", "accepted"] },
        "mutation_class": { "const": "multi_repo_low_risk" },
        "current_class": { "const": "low_risk_code" },
        "next_class": { "const": "multi_repo_low_risk" },
        "current_proven_live_class": { "$ref": "#/$defs/mutation_class" },
        "lower_class_live_evidence_status": { "type": "string", "minLength": 1 },
        "safe_to_request": { "type": "boolean" },
        "safe_to_execute": { "type": "boolean" },
        "live_execution_authority": { "type": "boolean" },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "denial_reason": { "type": "string", "minLength": 1 },
        "exact_next_action": {
          "enum": [
            "complete_low_risk_code_live_rehearsal_before_multi_repo_live",
            "request_repo_one_multi_repo_low_risk_live_rehearsal"
          ]
        },
        "repo_execution_policy": { "const": "sequenced_dry_run_only" },
        "schedules_work": { "const": false },
        "executes_work": { "const": false },
        "mutates_repositories": { "const": false }
      }
    },
    "low_risk_code_live_success": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "status",
        "mutation_class",
        "proven_live_class",
        "repo",
        "pull_request",
        "pull_request_number",
        "base_branch",
        "work_branch",
        "merge_commit",
        "merge_state",
        "changed_files",
        "file_allowlist"
      ],
      "properties": {
        "schema_version": { "const": "ao.foundry.low-risk-code-live-success-readback.v0.1" },
        "status": { "enum": ["accepted", "passed"] },
        "mutation_class": { "const": "low_risk_code" },
        "proven_live_class": { "const": "low_risk_code" },
        "repo": { "const": "ao-atlas" },
        "pull_request": { "type": "string", "minLength": 1 },
        "pull_request_number": { "const": 37 },
        "base_branch": { "const": "main" },
        "work_branch": { "const": "codex/low-risk-code-rehearsal-one" },
        "merge_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "merge_state": { "const": "merged" },
        "changed_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "file_allowlist": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "complex_node_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "status",
        "mutation_class",
        "highest_proven_live_class",
        "next_denied_class",
        "workgraph_id",
        "node_id",
        "task_id",
        "safe_to_request",
        "safe_to_execute",
        "live_execution_authority",
        "first_failing_check",
        "blockers",
        "exact_next_action",
        "foundry_import_id",
        "foundry_import_status",
        "foundry_import_task_count",
        "foundry_import_schedules_work",
        "foundry_import_executes_work",
        "foundry_import_approves_work",
        "candidate_status",
        "candidate_executable_ready",
        "candidate_safe_to_execute",
        "rollback_status",
        "rollback_safe_to_execute",
        "authority_boundary",
        "required_gates",
        "source_evidence",
        "schedules_work",
        "executes_work",
        "approves_work",
        "mutates_repositories",
        "fully_unsupervised_complex_mutation",
        "rsi"
      ],
      "properties": {
        "schema_version": { "const": "ao.foundry.complex-repo-mutation-node-gate.v0.1" },
        "status": { "enum": ["ready", "blocked"] },
        "mutation_class": { "const": "complex_repo_mutation" },
        "highest_proven_live_class": { "const": "multi_repo_low_risk" },
        "next_denied_class": { "const": "complex_repo_mutation" },
        "workgraph_id": { "type": "string", "minLength": 1 },
        "node_id": { "type": "string", "minLength": 1 },
        "task_id": { "type": "string", "minLength": 1 },
        "safe_to_request": { "type": "boolean" },
        "safe_to_execute": { "type": "boolean" },
        "live_execution_authority": { "type": "boolean" },
        "first_failing_check": { "type": "string" },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "exact_next_action": {
          "enum": [
            "complete_complex_node_gate_prerequisites_before_execution",
            "execute_exact_complex_node_candidate"
          ]
        },
        "foundry_import_id": { "type": "string", "minLength": 1 },
        "foundry_import_status": { "type": "string", "minLength": 1 },
        "foundry_import_task_count": { "type": "integer", "minimum": 0 },
        "foundry_import_schedules_work": { "type": "boolean" },
        "foundry_import_executes_work": { "type": "boolean" },
        "foundry_import_approves_work": { "type": "boolean" },
        "candidate_status": { "type": "string", "minLength": 1 },
        "candidate_executable_ready": { "type": "boolean" },
        "candidate_safe_to_execute": { "type": "boolean" },
        "rollback_status": { "type": "string", "minLength": 1 },
        "rollback_safe_to_execute": { "type": "boolean" },
        "authority_boundary": { "const": "complex_node_exact_scope_only" },
        "required_gates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_evidence": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "path", "schema_version", "status", "sha256"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "schema_version": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "schedules_work": { "const": false },
        "executes_work": { "const": false },
        "approves_work": { "const": false },
        "mutates_repositories": { "const": false },
        "fully_unsupervised_complex_mutation": { "const": "denied" },
        "rsi": { "const": "denied" }
      }
    },
    "repo_execution_plan": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo",
          "order",
          "planned_pr",
          "status",
          "execution_status",
          "write_scope",
          "rollback_scope",
          "rollback_required",
          "rollback_status",
          "repo_state_status",
          "repo_state_observed_at_utc",
          "repo_state_expires_at_utc",
          "depends_on",
          "merge_after"
        ],
        "properties": {
          "repo": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 1 },
          "planned_pr": { "type": "string", "minLength": 1 },
          "status": { "enum": ["ready"] },
          "execution_status": { "enum": ["sequenced_dry_run_only", "ready_to_execute"] },
          "write_scope": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "rollback_scope": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "rollback_required": { "const": true },
          "rollback_status": { "enum": ["ready"] },
          "repo_state_status": { "const": "clean_synced" },
          "repo_state_observed_at_utc": {
            "type": "string",
            "minLength": 1
          },
          "repo_state_expires_at_utc": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "merge_after": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "repo_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "max_active_repos",
        "concurrent_execution_allowed",
        "unsafe_concurrent_execution_prevented",
        "required_serialized_dependency_order",
        "kill_switch_state",
        "live_multi_repo_execution_authority"
      ],
      "properties": {
        "policy": { "const": "prevent_concurrent_unsafe_execution" },
        "max_active_repos": { "const": 1 },
        "concurrent_execution_allowed": { "const": false },
        "unsafe_concurrent_execution_prevented": { "const": true },
        "required_serialized_dependency_order": { "const": true },
        "kill_switch_state": { "const": "armed" },
        "live_multi_repo_execution_authority": { "const": false }
      }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "mutates_repositories": { "const": false }
  },
  "$defs": {
    "mutation_class": {
      "enum": [
        "docs_only_single_file",
        "docs_only_multi_file",
        "docs_config_only",
        "test_only",
        "low_risk_code",
        "multi_repo_low_risk",
        "complex_repo_mutation"
      ]
    }
  }
}
