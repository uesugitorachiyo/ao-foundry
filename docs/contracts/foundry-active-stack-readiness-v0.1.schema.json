{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-active-stack-readiness-v0.1.schema.json",
  "title": "AO Foundry Active Stack Readiness v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "generated_from_registry",
    "last_sweep_date",
    "status",
    "repositories",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.active-stack-readiness.v0.1" },
    "registry_id": { "type": "string", "minLength": 1 },
    "generated_from_registry": { "type": "string", "minLength": 1 },
    "last_sweep_date": { "type": "string", "minLength": 10 },
    "status": { "type": "string", "enum": ["ready", "blocked"] },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/repository" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "role", "status", "verification_evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["ready", "blocked"] },
        "ci": { "$ref": "#/$defs/ci" },
        "verification_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["success", "manual", "not_checked"] },
        "run_id": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 }
      }
    }
  }
}
