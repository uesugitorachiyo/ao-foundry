{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-live-docs-worktree-prepare-v0.1.schema.json",
  "title": "AO Foundry Live Docs Worktree Prepare v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "can_start_docs_only_pr_rehearsal",
    "allowed_next_action",
    "first_failing_check",
    "candidate_id",
    "target_repo",
    "change_class",
    "worktree",
    "change_plan",
    "source_hashes",
    "checks",
    "blocking_next_actions",
    "maintenance_suggestions",
    "authority_boundaries"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.live-docs-worktree-prepare.v0.1" },
    "status": { "enum": ["ready", "blocked"] },
    "can_start_docs_only_pr_rehearsal": { "type": "boolean" },
    "allowed_next_action": { "type": "string", "minLength": 1 },
    "first_failing_check": { "type": "string" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "target_repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "remote", "target_branch"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "remote": { "type": "string", "pattern": "^uesugitorachiyo/[a-z0-9][a-z0-9_-]*$" },
        "target_branch": { "const": "main" }
      }
    },
    "change_class": { "const": "docs_only" },
    "worktree": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "branch",
        "base_branch",
        "clean",
        "reused",
        "active_elsewhere",
        "has_untracked_changes",
        "remote_branch_exists"
      ],
      "properties": {
        "path": { "type": "string", "pattern": "^\\.foundry-local/worktrees/[A-Za-z0-9._/-]+$" },
        "branch": { "type": "string", "pattern": "^codex/live-docs-[A-Za-z0-9._/-]+$" },
        "base_branch": { "const": "main" },
        "clean": { "type": "boolean" },
        "reused": { "type": "boolean" },
        "active_elsewhere": { "type": "boolean" },
        "has_untracked_changes": { "type": "boolean" },
        "remote_branch_exists": { "type": "boolean" }
      }
    },
    "change_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changed_files",
        "docs_only_path_allowlist",
        "forbidden_paths",
        "max_changed_files"
      ],
      "properties": {
        "changed_files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": { "type": "string", "pattern": "^docs/[A-Za-z0-9._/-]+\\.md$" }
        },
        "docs_only_path_allowlist": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^docs/[A-Za-z0-9._/-]*/$" }
        },
        "forbidden_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(\\.github/|cmd/|internal/|scripts/|docs/contracts/|examples/|go\\.mod|go\\.sum|LICENSE|SECURITY\\.md|README\\.md)$"
          }
        },
        "max_changed_files": { "type": "integer", "minimum": 1, "maximum": 2 }
      }
    },
    "source_hashes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "schema_version", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": {
            "type": "string",
            "pattern": "^(docs|examples|scripts|target|tmp)/[A-Za-z0-9._/-]+$"
          },
          "schema_version": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "summary"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "blocked"] },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "blocking_next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "maintenance_suggestions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "authority_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_only",
        "live_mutation_allowed",
        "mutates_repositories",
        "creates_worktree",
        "creates_branch",
        "schedules_work",
        "executes_work",
        "approves_work",
        "provider_calls_allowed",
        "release_or_publish_allowed"
      ],
      "properties": {
        "validation_only": { "const": true },
        "live_mutation_allowed": { "const": false },
        "mutates_repositories": { "const": false },
        "creates_worktree": { "const": false },
        "creates_branch": { "const": false },
        "schedules_work": { "const": false },
        "executes_work": { "const": false },
        "approves_work": { "const": false },
        "provider_calls_allowed": { "const": false },
        "release_or_publish_allowed": { "const": false }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "can_start_docs_only_pr_rehearsal": { "const": true },
          "first_failing_check": { "const": "" },
          "blocking_next_actions": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "blocked" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "can_start_docs_only_pr_rehearsal": { "const": false },
          "first_failing_check": { "minLength": 1 },
          "blocking_next_actions": { "minItems": 1 }
        }
      }
    }
  ]
}
