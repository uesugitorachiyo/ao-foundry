{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-release-manifest-v0.1.schema.json",
  "title": "AO Foundry Release Manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "files", "checks"],
  "properties": {
    "schema_version": { "const": "ao.foundry.release-manifest.v0.1" },
    "status": { "type": "string", "enum": ["ready", "blocked"] },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/file" }
    },
    "checks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
