{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-pulse-event-v0.1.schema.json",
  "title": "AO Foundry Pulse Event v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pulse_id",
    "status",
    "score",
    "max_score",
    "registry_id",
    "task_id",
    "goal_id",
    "artifacts",
    "checks",
    "freshness_summary",
    "next_action"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.pulse-event.v0.1" },
    "pulse_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["ready", "blocked"] },
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "max_score": { "const": 100 },
    "registry_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "goal_id": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    },
    "freshness_summary": { "$ref": "#/$defs/freshness_summary" },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "freshness_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "status", "forge_live_packet", "control_plane_readback", "explanation"],
      "properties": {
        "schema_version": { "const": "ao.foundry.pulse-freshness-summary.v0.1" },
        "status": { "type": "string", "enum": ["ready", "blocked"] },
        "forge_live_packet": { "type": "string", "enum": ["not_provided", "ready", "stale", "blocked", "failed"] },
        "control_plane_readback": { "type": "string", "enum": ["not_provided", "ready", "stale", "blocked"] },
        "explanation": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "sha256", "schema_version", "status"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "schema_version": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "reason"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
