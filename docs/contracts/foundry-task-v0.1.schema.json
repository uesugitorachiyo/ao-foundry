{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-task-v0.1.schema.json",
  "title": "AO Foundry Task v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "title",
    "objective",
    "priority",
    "state",
    "target_repos",
    "required_delegations",
    "acceptance",
    "verification",
    "safety"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.task.v0.1" },
    "task_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "priority": { "type": "string", "enum": ["low", "normal", "high"] },
    "state": {
      "type": "string",
      "enum": ["queued", "planned", "delegated", "verifying", "passed", "blocked", "failed"]
    },
    "target_repos": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_delegations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/delegation" }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "safety": { "$ref": "#/$defs/safety" }
  },
  "$defs": {
    "delegation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delegate_to", "reason"],
      "properties": {
        "delegate_to": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_only", "allowed_write_roots", "forbidden_actions"],
      "properties": {
        "local_only": { "type": "boolean" },
        "allow_network": { "type": "boolean" },
        "allow_release_mutation": { "type": "boolean" },
        "allowed_write_roots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
