{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-run-v0.1.schema.json",
  "title": "AO Foundry Run v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "registry_id",
    "status",
    "delegated_to",
    "forge_packet",
    "evidence",
    "decisions",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.run.v0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "registry_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["queued", "planned", "delegated", "verifying", "passed", "blocked", "failed"]
    },
    "delegated_to": { "const": "ao-forge" },
    "forge_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "status"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "status": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/decision" }
    },
    "next_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/next_action" }
    }
  },
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "path", "sha256", "schema_version", "status"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "schema_version": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "target", "decision", "explanation"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "minLength": 1 },
        "explanation": { "type": "string", "minLength": 1 },
        "source": { "type": "string" }
      }
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "description", "required"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" }
      }
    }
  }
}
