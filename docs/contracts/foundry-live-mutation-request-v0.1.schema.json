{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-live-mutation-request-v0.1.schema.json",
  "title": "AO Foundry Live Mutation Request v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "mode",
    "status",
    "requested_authority_schema",
    "target_repo",
    "change_class",
    "objective",
    "allowed_path_class",
    "branch_isolation",
    "rollback_required",
    "pr_lifecycle_required",
    "operator_kill_switch_required",
    "source_evidence",
    "authority_boundaries",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.live-mutation-request.v0.1" },
    "request_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "mode": { "const": "dry_run_only" },
    "status": { "enum": ["ready", "blocked", "denied"] },
    "requested_authority_schema": { "const": "covenant.live-mutation-authority.v1" },
    "target_repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "remote", "target_branch"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "remote": { "type": "string", "pattern": "^uesugitorachiyo/[a-z0-9][a-z0-9_-]*$" },
        "target_branch": { "const": "main" }
      }
    },
    "change_class": { "enum": ["docs_only", "fixture_only", "test_only"] },
    "objective": { "type": "string", "minLength": 1 },
    "allowed_path_class": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "paths"],
      "properties": {
        "class": { "enum": ["docs", "examples", "tests"] },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(docs|examples|tests)/[A-Za-z0-9._/-]+$"
          }
        }
      }
    },
    "branch_isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "branch_prefix", "clean_worktree_required", "reuse_allowed"],
      "properties": {
        "required": { "const": true },
        "branch_prefix": { "const": "codex/" },
        "clean_worktree_required": { "const": true },
        "reuse_allowed": { "const": false }
      }
    },
    "rollback_required": { "const": true },
    "pr_lifecycle_required": { "const": true },
    "operator_kill_switch_required": { "const": true },
    "source_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "schema_version", "status", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": {
            "type": "string",
            "pattern": "^(docs|examples|tests|target)/[A-Za-z0-9._/-]+$"
          },
          "schema_version": { "type": "string", "minLength": 1 },
          "status": { "enum": ["ready", "passed", "blocked"] },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "authority_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run_only",
        "live_mutation_allowed",
        "provider_calls_allowed",
        "release_or_publish_allowed",
        "sibling_repo_mutation_allowed"
      ],
      "properties": {
        "dry_run_only": { "const": true },
        "live_mutation_allowed": { "const": false },
        "provider_calls_allowed": { "const": false },
        "release_or_publish_allowed": { "const": false },
        "sibling_repo_mutation_allowed": { "const": false }
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
