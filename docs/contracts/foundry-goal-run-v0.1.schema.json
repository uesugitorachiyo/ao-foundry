{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-goal-run-v0.1.schema.json",
  "title": "AO Foundry GoalRun v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "goal_id",
    "objective",
    "acceptance_criteria",
    "allowed_scope",
    "stop_conditions",
    "current_phase",
    "next_task",
    "continuation_prompt",
    "loop_owner",
    "next_action_guard",
    "last_iteration"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.goal-run.v0.1" },
    "goal_id": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "current_phase": {
      "type": "string",
      "enum": ["planning", "implementation", "verification", "blocked", "backoff", "complete", "stopped"]
    },
    "next_task": { "type": "string", "minLength": 1 },
    "continuation_prompt": { "type": "string", "minLength": 1 },
    "loop_owner": { "type": "string", "minLength": 1 },
    "next_action_guard": { "type": "string", "minLength": 1 },
    "last_iteration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence"],
      "properties": {
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "loop_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 0 },
        "iterations": { "type": "integer", "minimum": 0 },
        "max_elapsed_minutes": { "type": "integer", "minimum": 0 },
        "elapsed_minutes": { "type": "integer", "minimum": 0 },
        "max_spend_cents": { "type": "integer", "minimum": 0 },
        "spend_cents": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "path", "sha256"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
