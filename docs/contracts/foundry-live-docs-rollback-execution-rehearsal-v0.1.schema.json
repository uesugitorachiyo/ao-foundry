{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-live-docs-rollback-execution-rehearsal-v0.1.schema.json",
  "title": "AO Foundry Live Docs Rollback Execution Rehearsal v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "mode",
    "rollback_verified",
    "candidate_id",
    "target_repo",
    "target_file",
    "source_hashes",
    "execution_summary",
    "checks",
    "first_failing_check",
    "blocking_next_actions",
    "maintenance_suggestions",
    "authority_boundaries"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.live-docs-rollback-execution-rehearsal.v0.1" },
    "status": { "enum": ["ready", "blocked"] },
    "mode": { "const": "fixture_workspace_only" },
    "rollback_verified": { "type": "boolean" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "target_repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "remote", "target_branch"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "remote": { "type": "string", "pattern": "^uesugitorachiyo/[a-z0-9][a-z0-9_-]*$" },
        "target_branch": { "const": "main" }
      }
    },
    "target_file": { "type": "string", "pattern": "^docs/[A-Za-z0-9._/-]+\\.md$" },
    "source_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "schema_version", "sha256"],
        "properties": {
          "name": { "enum": ["candidate", "proposed_patch", "rollback_patch"] },
          "path": {
            "type": "string",
            "pattern": "^examples/live-docs-rollback-execution/[A-Za-z0-9._/-]+\\.(json|patch)$"
          },
          "schema_version": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "execution_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proposed_patch_applied",
        "rollback_patch_applied",
        "target_after_apply_sha256",
        "target_after_rollback_sha256",
        "fixture_workspace_removed"
      ],
      "properties": {
        "proposed_patch_applied": { "type": "boolean" },
        "rollback_patch_applied": { "type": "boolean" },
        "target_after_apply_sha256": { "type": "string" },
        "target_after_rollback_sha256": { "type": "string" },
        "fixture_workspace_removed": { "const": true }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "summary"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "blocked"] },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "first_failing_check": { "type": "string" },
    "blocking_next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "maintenance_suggestions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "authority_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_workspace_only",
        "live_mutation_allowed",
        "mutates_repositories",
        "schedules_work",
        "executes_work",
        "approves_work",
        "provider_calls_allowed",
        "release_or_publish_allowed"
      ],
      "properties": {
        "fixture_workspace_only": { "const": true },
        "live_mutation_allowed": { "const": false },
        "mutates_repositories": { "const": false },
        "schedules_work": { "const": false },
        "executes_work": { "const": false },
        "approves_work": { "const": false },
        "provider_calls_allowed": { "const": false },
        "release_or_publish_allowed": { "const": false }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "rollback_verified": { "const": true },
          "first_failing_check": { "const": "" },
          "blocking_next_actions": { "maxItems": 0 },
          "source_hashes": { "minItems": 3 },
          "execution_summary": {
            "properties": {
              "proposed_patch_applied": { "const": true },
              "rollback_patch_applied": { "const": true },
              "target_after_apply_sha256": { "pattern": "^[a-f0-9]{64}$" },
              "target_after_rollback_sha256": { "pattern": "^[a-f0-9]{64}$" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "blocked" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "rollback_verified": { "const": false },
          "first_failing_check": { "minLength": 1 },
          "blocking_next_actions": { "minItems": 1 }
        }
      }
    }
  ]
}
