{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-first-live-docs-readiness-rollup-v0.1.schema.json",
  "title": "AO Foundry First Live Docs Readiness Rollup v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "first_live_class",
    "approved_scope",
    "safe_to_request",
    "safe_to_execute",
    "explicit_operator_approval_required",
    "exact_next_step",
    "first_failing_check",
    "evidence",
    "blocking_next_actions",
    "maintenance_suggestions",
    "authority_boundaries"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.first-live-docs-readiness-rollup.v0.1" },
    "status": { "enum": ["ready", "blocked"] },
    "first_live_class": { "const": "docs_only" },
    "approved_scope": { "const": "docs_only" },
    "safe_to_request": { "type": "boolean" },
    "safe_to_execute": { "type": "boolean" },
    "explicit_operator_approval_required": { "type": "boolean" },
    "exact_next_step": { "type": "string", "minLength": 1 },
    "first_failing_check": { "type": "string" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved_live_docs_dry_run_chain", "live_docs_pr_rehearsal_gate", "source_artifacts"],
      "properties": {
        "approved_live_docs_dry_run_chain": { "$ref": "#/$defs/evidence_ref" },
        "live_docs_pr_rehearsal_gate": { "$ref": "#/$defs/evidence_ref" },
        "source_artifacts": {
          "type": "array",
          "minItems": 10,
          "items": { "$ref": "#/$defs/source_artifact" }
        }
      }
    },
    "blocking_next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "maintenance_suggestions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "authority_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "emits_rollup_only",
        "live_mutation_performed",
        "mutates_repositories",
        "creates_branch",
        "creates_worktree",
        "opens_pr",
        "merges_pr",
        "schedules_work",
        "executes_work",
        "approves_work",
        "provider_calls_allowed",
        "release_or_publish_allowed",
        "broad_live_mutation_allowed",
        "fully_unsupervised_complex_mutation_claimed"
      ],
      "properties": {
        "emits_rollup_only": { "const": true },
        "live_mutation_performed": { "const": false },
        "mutates_repositories": { "const": false },
        "creates_branch": { "const": false },
        "creates_worktree": { "const": false },
        "opens_pr": { "const": false },
        "merges_pr": { "const": false },
        "schedules_work": { "const": false },
        "executes_work": { "const": false },
        "approves_work": { "const": false },
        "provider_calls_allowed": { "const": false },
        "release_or_publish_allowed": { "const": false },
        "broad_live_mutation_allowed": { "const": false },
        "fully_unsupervised_complex_mutation_claimed": { "const": false }
      }
    }
  },
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "schema_version", "sha256", "status"],
      "properties": {
        "path": { "type": "string", "pattern": "^(examples|target|docs)/[A-Za-z0-9._/-]+\\.json$" },
        "schema_version": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "status": { "enum": ["ready", "blocked"] }
      }
    },
    "source_artifact": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "path", "schema_version", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "safe_to_request": { "const": true },
          "safe_to_execute": { "const": true },
          "explicit_operator_approval_required": { "const": false },
          "exact_next_step": { "const": "start_first_docs_only_live_pr_rehearsal" },
          "first_failing_check": { "const": "" },
          "blocking_next_actions": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "blocked" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "safe_to_execute": { "const": false },
          "explicit_operator_approval_required": { "const": true },
          "first_failing_check": { "minLength": 1 },
          "blocking_next_actions": { "minItems": 1 }
        }
      }
    }
  ]
}
