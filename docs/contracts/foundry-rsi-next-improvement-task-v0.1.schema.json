{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-rsi-next-improvement-task-v0.1.schema.json",
  "title": "AO Foundry RSI Next Improvement Task v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "generated_by",
    "goal_id",
    "recommended_task_id",
    "recommended_action",
    "improvement_rationale",
    "candidate_evidence_path",
    "gate_evidence_path",
    "required_improvement_percent",
    "actual_improvement_percent",
    "autonomous_claim",
    "mutates_repositories",
    "next_actions"
  ],
  "properties": {
    "schema_version": { "const": "ao.foundry.rsi-next-improvement-task.v0.1" },
    "status": { "type": "string", "enum": ["ready"] },
    "generated_by": { "type": "string", "enum": ["foundry pulse run"] },
    "goal_id": { "type": "string", "minLength": 1 },
    "recommended_task_id": { "type": "string", "minLength": 1 },
    "recommended_action": { "type": "string", "minLength": 1 },
    "improvement_rationale": { "type": "string", "minLength": 1 },
    "candidate_evidence_path": { "type": "string", "minLength": 1 },
    "gate_evidence_path": { "type": "string", "minLength": 1 },
    "required_improvement_percent": { "type": "number", "exclusiveMinimum": 0 },
    "actual_improvement_percent": { "type": "number", "minimum": 0 },
    "autonomous_claim": {
      "type": "string",
      "enum": ["derived_local_next_improvement"]
    },
    "mutates_repositories": { "const": false },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
