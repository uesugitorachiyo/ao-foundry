{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-loop-lease-v0.1.schema.json",
  "title": "AO Foundry Loop Lease v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "goal_id", "lease_id", "acquired_at_utc", "expires_at_utc", "status"],
  "properties": {
    "schema_version": { "const": "ao.foundry.loop-lease.v0.1" },
    "goal_id": { "type": "string", "minLength": 1 },
    "lease_id": { "type": "string", "minLength": 1 },
    "acquired_at_utc": { "type": "string", "format": "date-time" },
    "expires_at_utc": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["active", "released", "stale"] }
  }
}
