{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-foundry/docs/contracts/foundry-release-candidate-v0.1.schema.json",
  "title": "AO Foundry Release Candidate v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "candidate_id", "status", "active_spine", "gates", "next_actions"],
  "properties": {
    "schema_version": { "const": "ao.foundry.release-candidate.v0.1" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["ready", "blocked"] },
    "active_spine": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/repository" }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/gate" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "role", "status", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["ready", "blocked"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "required_before_promotion", "evidence"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["ready", "manual_required", "blocked"] },
        "required_before_promotion": { "type": "boolean" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
